@page
@model DagligVareLevering.Models.CartModel

<h2>My Cart</h2>

@if (Model.BasketItems.Count == 0)
{
    <div class="empty-cart">
        <p>Your cart is empty.</p>
    </div>
}
else
{
    <table class="cart-table">
        <thead>
            <tr>
                <th>Produkt</th>
                <th>Antal</th>
                <th>Pris </th>
                <th>Total Pris</th>
                <th>Handlinger</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.BasketItems)
            {
                <tr>
                    <td>@item.Product.Name</td>

                    <td>
                        <div class="quantity-box">
                            <form method="post" asp-page-handler="Decrease">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn-small">-</button>
                            </form>

                            <span class="quantity">@item.Quantity</span>

                            <form method="post" asp-page-handler="Increase">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn-small">+</button>
                            </form>
                        </div>
                    </td>

                    <td>@item.Product.Price.ToString("C")</td>
                    <td>@((item.Product.Price * item.Quantity).ToString("C"))</td>

                    <td>
                        <form method="post" asp-page-handler="Remove">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="btn-remove">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="cart-total">
    <p><strong>Varenes samlet pris:</strong> @Model.ItemsTotalPrice.ToString("C")</p>
    <p><strong>Leveringspris:</strong> @Model.DeliveryPrice.ToString("C")</p>
    <p class="grand-total"><strong>Samlet pris:</strong> @Model.TotalWithDelivery.ToString("C")</p>
</div>

@if (Model.BasketItems.Count > 0)
{
    <form method="post" asp-page-handler="Checkout" class="checkout-actions">
        <button type="submit" class="checkout-btn">Fortsæt til levering →</button>
    </form>
}


<style>
    h2 {
        margin-bottom: 20px;
        color: #333;
    }

    .cart-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        background-color: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        border-radius: 8px;
        overflow: hidden;
    }

        .cart-table th {
            background-color: #f4f4f4;
            text-align: left;
            padding: 12px;
        }

        .cart-table td {
            padding: 12px;
            border-top: 1px solid #ddd;
            vertical-align: middle;
        }

        .cart-table tr:hover {
            background-color: #f9f9f9;
        }

    .empty-cart {
        padding: 20px;
        background-color: #f8f8f8;
        border-radius: 8px;
        color: #666;
    }

    .cart-total {
        margin-top: 20px;
        font-size: 18px;
        text-align: right;
    }

    .quantity-box {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .quantity {
        font-weight: bold;
        min-width: 20px;
        text-align: center;
    }

    .btn-small {
        padding: 4px 10px;
        border-radius: 4px;
        background-color: #6c757d;
        color: white;
        border: none;
        cursor: pointer;
    }

        .btn-small:hover {
            opacity: 0.85;
        }

    .btn-remove {
        padding: 6px 12px;
        border-radius: 6px;
        background-color: #d9534f;
        color: white;
        border: none;
        cursor: pointer;
    }

        .btn-remove:hover {
            opacity: 0.85;
        }

    form {
        display: inline;
    }
    
    .cart-total{
        margin-top: 20px;
        margin-left: auto;
        width: 280px;
        background-color: #f8f8f8;
        padding: 16px;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.06);
    }

    .cart-total p {
        margin: 8px 0;
            font-size: 16px;
    }

    .grand-total {
        margin-top: 12px;
        font-size: 18px;   
        color: #222;
    }

    .checkout-actions {
        margin-top: 24px;
        text-align: right;
    }

    .checkout-actions .checkout-btn {
            display: inline-block;
            padding: 14px 24px;
            background-color: #4f46e5;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 16px;
            box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3);
            transition: 0.2s ease;
    }

            .checkout-actions .checkout-btn:hover {
                background-color: #4338ca;
                color: white;
                transform: translateY(-1px);
                box-shadow: 0 6px 14px rgba(79, 70, 229, 0.4);
            }

</style>